# Optional: enables LLM-drafted actions and emails. Without it, DealRadar
# falls back to a deterministic rule-based drafter so the demo always works.
OPENAI_API_KEY=
# Optional, defaults to gpt-4o-mini
OPENAI_MODEL=

# Optional: Supabase persistence. Without these, DealRadar uses an in-memory
# store (data resets on restart). Create a project at https://supabase.com,
# run supabase/schema.sql in the SQL editor, then paste the values from
# Project Settings -> API. Demo deals are seeded automatically on first run.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only; used by API routes and the MCP server. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=
